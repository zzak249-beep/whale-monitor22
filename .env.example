# ── BingX API ────────────────────────────────────────────
BINGX_API_KEY=tu_api_key_aqui
BINGX_SECRET_KEY=tu_secret_key_aqui

# ── Telegram ─────────────────────────────────────────────
TELEGRAM_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=-100123456789

# ── Símbolos (separados por coma) ─────────────────────────
SYMBOLS=BTC-USDT,ETH-USDT

# ── Gestión de riesgo ─────────────────────────────────────
RISK_PER_TRADE=1.0        # % del capital por operación
MAX_DAILY_LOSS=5.0        # % de pérdida diaria máxima
MAX_OPEN_TRADES=2         # Trades simultáneos máximos
RISK_REWARD=2.5           # Ratio riesgo/beneficio mínimo
LEVERAGE=10               # Apalancamiento

# ── Horario de trading (UTC) ──────────────────────────────
TRADE_HOURS_UTC=7-23      # Formato HH-HH

# ── Sistema ───────────────────────────────────────────────
LOG_LEVEL=INFO
DRY_RUN=true              # true = paper trading, false = live
POLL_INTERVAL=15          # Segundos entre ciclos de polling
AVOID_NEWS=true
