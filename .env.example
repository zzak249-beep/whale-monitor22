# Exchange Configuration
EXCHANGE_KEY=your_binance_api_key
EXCHANGE_SECRET=your_binance_api_secret
EXCHANGE_URL=https://fapi.binance.com

# Trading Parameters
LEVERAGE=10
TOP_N_SYMBOLS=50
MIN_VOLUME_USDT=100000
MAX_OPEN_TRADES=5
SCAN_INTERVAL=5

# Risk Management
MAX_RISK_PER_TRADE=1.0
MAX_DAILY_LOSS=500
TRAILING_SL=true

# Signal Parameters
MIN_CONFIDENCE=65
ADX_THRESHOLD=25
RSI_OVERSOLD=30
RSI_OVERBOUGHT=70

# Telegram Configuration
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Dashboard
DASHBOARD_ENABLED=true
DASHBOARD_PORT=8000

# Database
DB_PATH=data/trades.db

# Blacklist (comma-separated)
BLACKLIST=BNBUSDT,BUSDUSDT
