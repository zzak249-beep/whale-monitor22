# ═══════════════════════════════════════════════════
#  UltraBot v3 — Railway Environment Variables
#  Copy these into Railway → Variables tab
# ═══════════════════════════════════════════════════

# ── REQUIRED ─────────────────────────────────────
BINGX_API_KEY=your_bingx_api_key_here
BINGX_SECRET_KEY=your_bingx_secret_key_here
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── STRATEGY ─────────────────────────────────────
TIMEFRAME=15m
CONFIRM_TF=1h
TREND_TF=4h
PERIOD=20
ADX_LEN=14
ADX_THRESH=25
RSI_LEN=14
RSI_OB=70
RSI_OS=30
VOL_SPIKE_MULT=1.6
MIN_CONFIDENCE=52

# ── UNIVERSE ─────────────────────────────────────
MIN_VOLUME_USDT=2000000
TOP_N_SYMBOLS=50
BLACKLIST=LUNA-USDT,FTT-USDT,LUNC-USDT

# ── RISK ─────────────────────────────────────────
LEVERAGE=5
RISK_PCT=1.2
MAX_OPEN_TRADES=3
SL_PCT=2.0
TP_PCT=4.0
TRAILING_SL=true
MAX_DRAWDOWN_PCT=8.0
DAILY_LOSS_LIMIT=4.0
MAX_CONSECUTIVE_LOSSES=4
COOLDOWN_AFTER_LOSS=300

# ── PERFORMANCE ───────────────────────────────────
SCAN_INTERVAL=10
MAX_CONCURRENT=25
HTTP_TIMEOUT=8

# ── DASHBOARD ─────────────────────────────────────
DASHBOARD_ENABLED=true
DASHBOARD_PORT=8080
# Railway sets PORT automatically — no need to set it
