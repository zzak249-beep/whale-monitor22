# ─── BINGX API ────────────────────────────────────────────────
BINGX_API_KEY=tu_api_key_aqui
BINGX_SECRET_KEY=tu_secret_key_aqui

# ─── TELEGRAM ──────────────────────────────────────────────────
# Obtener token: habla con @BotFather en Telegram
TELEGRAM_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
# Obtener chat_id: habla con @userinfobot en Telegram
TELEGRAM_CHAT_ID=-1001234567890

# ─── SÍMBOLOS (separados por coma, sin espacios) ───────────────
SYMBOLS=BTC-USDT,ETH-USDT

# ─── RIESGO ────────────────────────────────────────────────────
RISK_PER_TRADE=1.0          # % del capital por trade (ej: 1.0 = 1%)
MAX_DAILY_LOSS=5.0          # % máximo de pérdida diaria
MAX_OPEN_TRADES=2           # Máximo de trades simultáneos
RISK_REWARD=2.5             # Ratio Riesgo/Beneficio mínimo
LEVERAGE=10                 # Apalancamiento (1-20 recomendado)

# ─── MODO ──────────────────────────────────────────────────────
# DRY_RUN=true → paper trading (SIN dinero real)
# DRY_RUN=false → trading REAL (¡cuidado!)
DRY_RUN=true

# ─── HORARIO (UTC) ─────────────────────────────────────────────
TRADE_HOURS_UTC=7-23        # Solo opera entre 7:00 y 23:00 UTC

# ─── SISTEMA ───────────────────────────────────────────────────
LOG_LEVEL=INFO              # DEBUG / INFO / WARNING / ERROR
POLL_INTERVAL=15            # Segundos entre ciclos de polling
