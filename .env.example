# Copia como .env — NUNCA subas este archivo a GitHub

BINGX_API_KEY=tu_api_key
BINGX_API_SECRET=tu_api_secret

TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_CHAT_ID=tu_chat_id

# --- Trading ---
TRADE_AMOUNT_USDT=10        # USDT por trade
MAX_OPEN_TRADES=3            # máximo de posiciones simultáneas
LEVERAGE=5                   # apalancamiento (5x = riesgo razonable para empezar)
MIN_BALANCE_USDT=20          # no operar si el balance cae por debajo de esto

# --- Comportamiento ---
SCAN_INTERVAL_SECONDS=60     # cada cuántos segundos escanea pares
TOP_N_SYMBOLS=20             # cuántos pares por volumen analizar
COOLDOWN_SECONDS=300         # pausa por símbolo tras cerrar un trade (5 min)
HEARTBEAT_MINUTES=60         # cada cuántos minutos manda resumen a Telegram
