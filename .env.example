# ── BingX ──────────────────────────────────────────────────
BINGX_API_KEY=tu_api_key_aqui
BINGX_SECRET_KEY=tu_secret_key_aqui

# ── Telegram ────────────────────────────────────────────────
TELEGRAM_TOKEN=tu_bot_token_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# ── Símbolos ────────────────────────────────────────────────
SYMBOLS=BTC-USDT,ETH-USDT

# ── Gestión de riesgo ───────────────────────────────────────
RISK_PER_TRADE=1.0      # % del capital por trade
MAX_DAILY_LOSS=5.0      # % pérdida diaria máxima
MAX_OPEN_TRADES=2       # trades simultáneos máximos
RISK_REWARD=2.5         # ratio riesgo/beneficio mínimo
LEVERAGE=10             # apalancamiento

# ── Filtros ─────────────────────────────────────────────────
TRADE_HOURS_UTC=7-23    # solo operar entre estas horas UTC

# ── Sistema ─────────────────────────────────────────────────
DRY_RUN=true            # true = paper trading (sin dinero real)
LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
POLL_INTERVAL=10        # segundos entre ciclos de polling REST
