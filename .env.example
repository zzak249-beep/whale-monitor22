# ════════════════════════════════════════════════════
#  THREE STEP FUTURE-TREND BOT v2.0 — Variables
# ════════════════════════════════════════════════════

# ── BingX ────────────────────────────────────────────
BINGX_API_KEY=tu_api_key_aqui
BINGX_SECRET_KEY=tu_secret_key_aqui
BINGX_TESTNET=true          # false = DINERO REAL

# ── Telegram ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdef...
TELEGRAM_CHAT_ID=-1001234567890

# ── Símbolos a escanear ───────────────────────────────
SYMBOLS=BTC-USDT,ETH-USDT,SOL-USDT,BNB-USDT,XRP-USDT,DOGE-USDT,ADA-USDT,AVAX-USDT

# ── Trading ───────────────────────────────────────────
TIMEFRAME=1h
TRADE_USDT=5.0              # USDT por trade (antes de leverage)
LEVERAGE=10                 # 10x
MAX_POSITIONS=3

# ── Estrategia Three Step ─────────────────────────────
PERIOD=25                   # Ventana volume delta
ATR_PERIOD=14
ATR_MULT=2.0                # SL = entry ± ATR_MULT × ATR
RR=2.0                      # TP1 = entry ± RR × ATR
TP2_MULT=3.5                # TP2 = entry ± TP2_MULT × ATR
PARTIAL_PCT=50              # % cerrar en TP1
BE_TRIGGER=0.5              # Breakeven al 50% de entry→TP1

# ── Runtime ───────────────────────────────────────────
SCAN_INTERVAL=300           # segundos entre ciclos
MAX_CONCURRENT=8
PORT=8080
MAX_DAILY_LOSS=50.0
